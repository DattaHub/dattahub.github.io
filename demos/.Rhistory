library(ggplot2)
library(dplyr)
library(scales)
set.seed(42)
n <- 100
# Thresholds are integer counts in [0, n].
# Agent i switches when the number already switched >= their threshold.
# Three distributions chosen to illustrate different cascade outcomes.
thresholds <- list(
"Uniform (full cascade)"        = 0:(n - 1),
"Normal mean=30, SD=20 (fast)"  = sort(pmin(pmax(round(rnorm(n, 30, 20)), 0), n)),
"Normal mean=50, SD=5 (stalls)" = sort(pmin(pmax(round(rnorm(n, 50,  5)), 0), n))
)
# Iterate: at each step, switch everyone whose threshold <= current count.
# Stop when no new agents switch (equilibrium).
run_cascade <- function(thresh) {
count <- 0
trajectory <- 0
repeat {
new_count <- sum(thresh <= count)
trajectory <- c(trajectory, new_count)
if (new_count == count) break
count <- new_count
}
trajectory / n   # return as share
}
max_steps <- 110
traj_df <- do.call(rbind, lapply(names(thresholds), function(nm) {
traj <- run_cascade(thresholds[[nm]])
traj <- c(traj, rep(tail(traj, 1), max_steps - length(traj) + 1))
data.frame(step  = 0:max_steps,
share = traj[1:(max_steps + 1)],
dist  = nm)
}))
traj_df$dist <- factor(traj_df$dist, levels = names(thresholds))
# ── plot ──────────────────────────────────────────────────────────────────────
col_bg   <- "#FAFAF8"
col_grid <- "#E8E6DF"
col_text <- "#2C2C2A"
cols     <- c("#D85A30", "#3B6D11", "#4A6FA5")
(p <- ggplot(traj_df, aes(step, share, colour = dist)) +
geom_hline(yintercept = 0.5, linetype = "dotted",
colour = "#aaaaaa", linewidth = 0.4) +
annotate("text", x = 70, y = 0.52, label = "50% majority",
size = 3, colour = "#aaaaaa") +
geom_step(linewidth = 1.1) +
scale_colour_manual(values = cols) +
scale_y_continuous(labels = percent_format(), limits = c(0, 1.05)) +
scale_x_continuous(limits = c(0, 115), breaks = seq(0, 110, 10)) +
labs(
title    = "Granovetter Threshold Model",
subtitle = paste0("n = ", n,
" agents. Cascade outcome depends on gap structure",
" of thresholds, not just their mean."),
x        = "Step",
y        = "Share switched",
colour   = NULL
) +
theme_minimal(base_size = 12) +
theme(
panel.grid.major = element_line(colour = col_grid, linewidth = 0.4),
panel.grid.minor = element_blank(),
plot.title       = element_text(size = 14, colour = col_text,
margin = margin(b = 4)),
plot.subtitle    = element_text(size = 9,  colour = "#5F5E5A",
margin = margin(b = 10)),
legend.position  = "bottom",
legend.text      = element_text(size = 9),
plot.margin      = margin(16, 16, 12, 16)
))
